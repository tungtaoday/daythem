# ── Development (defaults) ───────────────────────────────────────────────
ENV=dev
DATABASE_URL=sqlite:///./daythem.db
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_EXPIRE_DAYS=30
OTP_DEV_MODE=true
CORS_ORIGINS=*

# ── Production ───────────────────────────────────────────────────────────
# When ENV=prod the app REFUSES to boot unless these are set safely:
#   - SECRET_KEY: 32+ random chars, not a placeholder   (openssl rand -hex 32)
#   - OTP_DEV_MODE=false                                 (real SMS, code not echoed)
#   - DATABASE_URL: PostgreSQL (not SQLite)
#   - CORS_ORIGINS: explicit allowlist (not *)
#
# ENV=prod
# PostgreSQL:  DATABASE_URL=postgresql+psycopg2://user:password@host:5432/daythem
# MySQL:       DATABASE_URL=mysql+pymysql://user:password@host:3306/daythem_production?charset=utf8mb4
# SECRET_KEY=<openssl rand -hex 32>
# JWT_EXPIRE_DAYS=30
# OTP_DEV_MODE=false
# CORS_ORIGINS=https://app.daythem.vn,https://daythem.vn
#
# Run migrations before first boot / after deploys:  alembic upgrade head
#
# Tax thresholds (VND) — override only if the law changes:
# TAX_THRESHOLD_2025=100000000
# TAX_THRESHOLD_DEFAULT=200000000   # 2026+ (Luật 48/2024)
# TAX_RATE=0.02
# TZ_OFFSET_HOURS=7
